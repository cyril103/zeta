import option
import sequences

def main(): Int = {
    var values: Vec[Int] = Vec[Int]()
    values.push(30)
    values.push(10)
    values.push(40)
    values.push(20)
    values.push(10)

    val initiallySorted: Bool = sequences.isSorted(values.asSlice())
    val swaps: Int = sequences.sort(values.asSliceMut())
    val sorted: Bool = sequences.isSorted(values.asSlice())
    val firstTen: Int = option.unwrapOr(
        sequences.binarySearch(values.asSlice(), 10), -1)
    val forty: Int = option.unwrapOr(
        sequences.binarySearch(values.asSlice(), 40), -1)
    val missing: Bool = option.isNone(
        sequences.binarySearch(values.asSlice(), 25))
    val view: Slice[Int] = values.asSlice()
    val orderOk: Bool = view[0] == 10 && view[1] == 10 && view[2] == 20 &&
        view[3] == 30 && view[4] == 40

    var letters: [Char; 4] = ['d', 'a', 'c', 'b']
    val mutableLetters: SliceMut[Char] = SliceMut(&mut letters)
    val letterSwaps: Int = sequences.sort(mutableLetters)
    val lettersView: Slice[Char] = Slice(&letters)
    val lettersOk: Bool = sequences.isSorted(lettersView) &&
        letters[0] == 'a' && letters[3] == 'd'

    val empty: [Int; 0] = []
    val emptyView: Slice[Int] = Slice(&empty)
    val emptyOk: Bool = sequences.isSorted(emptyView) &&
        option.isNone(sequences.binarySearch(emptyView, 1))

    if (!initiallySorted && swaps > 0 && sorted && firstTen >= 0 && forty == 4 &&
        missing && orderOk && letterSwaps > 0 && lettersOk && emptyOk) 0 else 1
}

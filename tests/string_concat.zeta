import io

def join(left: String, right: String): String = left + right

def main(): Int = {
    val hello: String = "Bonjour"
    val separator: String = " "
    val message: String = join(hello + separator, "Zeta")
    val copy: String = message
    io.println(copy)
    if (message == "Bonjour Zeta") { 0 } else { 1 }
}

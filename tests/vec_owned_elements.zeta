def main(): Int = {
    val text: String = "toujours vivant"
    var texts: Vec[String] = Vec[String]()
    texts.push(text)
    texts.push("temporaire")
    texts.push("trois")
    texts.push("quatre")
    texts.push("croissance")
    texts.clear()

    var boxes: Vec[Box[Int]] = Vec[Box[Int]]()
    boxes.push(Box(40))
    boxes.push(Box(2))
    boxes.push(Box(3))
    boxes.push(Box(4))
    boxes.push(Box(5))
    boxes.clear()
    boxes.push(Box(42))

    if (text != "toujours vivant") 1 else {
        if (texts.capacity != 8) 2 else {
            if (boxes.length == 1) 0 else 3
        }
    }
}

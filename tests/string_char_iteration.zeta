import strings

def main(): Int = {
    val text: String = "hé€🚀"
    var offset: Int = 0
    var count: Int = 0
    var total: Int = 0
    while (offset < text.lengthBytes) do {
        val value: Char = strings.unwrapOr(strings.charAtByte(text, offset), '?')
        total = total + Int(value)
        offset = strings.nextByteOffset(text, offset)
        count = count + 1
    }
    val invalid: Bool = strings.isNone(strings.charAtByte(text, 2))
    if (count == 4 && offset == 10 && invalid &&
        total == Int('h') + Int('é') + Int('€') + Int('🚀')) 0 else 1
}

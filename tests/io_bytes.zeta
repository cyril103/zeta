import io

def main () : Int = {
    val message : [Byte; 9] = [90, 101, 116, 97, 32, 240, 159, 154, 128]
    val punctuation : [Byte; 1] = [33]
    val messageBytes : Slice[Byte] = Slice(&message)
    val punctuationBytes : Slice[Byte] = Slice(&punctuation)
    io.printBytes(messageBytes)
    io.printlnBytes(punctuationBytes)
    0
}

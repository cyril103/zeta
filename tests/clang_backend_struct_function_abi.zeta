struct Pair {
    left: Int
    right: Int
}


def makePair(base: Int): Pair = Pair { left: base + 10, right: base + 32 }


def sumPair(pair: Pair): Int = pair.left + pair.right


def shiftPair(pair: Pair, delta: Int): Pair = Pair { left: pair.left + delta, right: pair.right - delta }


def main(): Int = {
    val pair: Pair = makePair(0)
    val shifted: Pair = shiftPair(pair, 5)
    sumPair(shifted)
}

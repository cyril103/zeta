import collections
import option

def main(): Int = {
    val numbers: [Int; 3] = [10, 20, 12]
    val view: Slice[Int] = Slice(&numbers)
    val first: Int = option.unwrapOr(collections.first(view), 0)
    val second: Int = option.unwrapOr(collections.second(view), 0)
    val last: Int = option.unwrapOr(collections.at(view, 2), 0)
    val missing: Bool = option.isNone(collections.at(view, 3))
    val negative: Bool = option.isNone(collections.at(view, -1))
    if (first + second + last == 42 && missing && negative) {
        0
    } else {
        1
    }
}

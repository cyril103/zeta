enum MaybeInt {
    Some(value: Int)
    None
}

enum PairValue {
    Pair(left: Int, right: Int)
}

def make(value: Int): MaybeInt = MaybeInt.Some(value: value)
def pass(value: MaybeInt): MaybeInt = value
def consume(value: MaybeInt): Int = 0

def main(): Int = {
    val empty: MaybeInt = MaybeInt.None
    val present: MaybeInt = pass(make(42))
    consume(present) + consume(empty)
}

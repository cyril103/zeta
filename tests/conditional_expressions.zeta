def abs (x : Int) : Int = if (x < 0) -x else x

def signe (x : Int) : Int = if (x < 0) {
    -1
} else if (x > 0) {
    1
} else {
    0
}

def borne (x : Int) : Int = if (x < 0) {
    val minimum : Int = 0
    minimum
} else if (x > 10) {
    val maximum : Int = 10
    maximum
} else x

def choixDouble (condition : Bool) : Double = if (condition) 3.1415 else 2.5e-3

// La branche contenant la division par zéro ne doit pas être exécutée.
def sansErreur () : Int = if (true) 42 else 1 / 0

def main () : Int = {
    if (
        abs(-5) == 5 &&
        signe(-4) == -1 &&
        signe(0) == 0 &&
        signe(7) == 1 &&
        borne(50) == 10 &&
        choixDouble(true) == 3.1415 &&
        sansErreur() == 42
    ) 0 else 9
}

enum Resultat {
    Valeur(value: Int)
    Erreur(code: Byte, detail: Int)
    Absent
}

def decode(resultat: Resultat): Int = match (resultat) {
    Resultat.Valeur(value) => value
    Resultat.Erreur(code, detail) => Int(code) + detail
    Resultat.Absent => -1
}

def main(): Int = {
    val valeur: Int = decode(Resultat.Valeur(value: 42))
    val erreur: Int = decode(Resultat.Erreur(code: 2, detail: 5))
    val absent: Int = decode(Resultat.Absent)
    if (valeur == 42 && erreur == 7 && absent == -1) 0 else 1
}
